--SpeedBooster
local speedBoost = workspace:WaitForChild("SpeedBoost")
local debounce = false

speedBoost.Touched:Connect(function(hit)
	local humanoid = hit.Parent:FindFirstChild("Humanoid")
	if humanoid and not debounce then
		local OGSpeed = humanoid.WalkSpeed
		task.wait()
		humanoid.WalkSpeed += 50
		debounce = true
		task.wait(5)
		humanoid.WalkSpeed = OGSpeed
		debounce = false
	end
end)

--JumpPad
local JumpPads = workspace:WaitForChild("JumpPads")
local JumpSound = game.SoundService:WaitForChild("Jumpsound")

JumpPad.Touched:Connect(function(hit)
		local humanoid = hit.Parent:FindFirstChild("Humanoid")
		if humanoid and on == false then
			humanoid.JumpHeight = 100
			humanoid.Jump = true
			on = true
			JumpSound:Play()
			task.wait(0.3)
			humanoid.JumpHeight = 7.2
			on = false
		end
	end)

--Healer
local healer = workspace:WaitForChild("Healer")

healer.Touched:Connect(function(hit)
	local humanoid = hit.Parent:FindFirstChild("Humanoid")
	if humanoid then
		humanoid.Health = humanoid.Health + 2
	end
end)

--WindPusher
local zone = script.Parent
local velocity = Vector3.new(30, 0, 0)

zone.Touched:Connect(function(hit)
	local character = hit.Parent
	local root = character:FindFirstChild("HumanoidRootPart")

	if root then
		local attachment = Instance.new("Attachment")
		attachment.Parent = root

		local lv = Instance.new("LinearVelocity")
		lv.Attachment0 = attachment
		lv.VectorVelocity = velocity
		lv.MaxForce = math.huge
		lv.Parent = root

		game.Debris:AddItem(lv, 0.5)
		game.Debris:AddItem(attachment, 0.5)
	end
end)
