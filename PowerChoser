local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")

local screenGUI = script.Parent

local JumpButton = screenGUI:WaitForChild("Jump")
local SpeedButton = screenGUI:WaitForChild("Speed")
local PowerButton = screenGUI:WaitForChild("PowerChoser")

local player = game.Players.LocalPlayer

local tweenInfo = TweenInfo.new(0.01, Enum.EasingStyle.Linear)

local function getHumanoid()
	local character = player.Character or player.CharacterAdded:Wait()
	return character:WaitForChild("Humanoid")
end

PowerButton.MouseButton1Click:Connect(function()
	screenGUI.Frame.Visible = true
	JumpButton.Visible = true 
	SpeedButton.Visible = true 
	PowerButton.Visible = false 
end)

JumpButton.MouseButton1Click:Connect(function()
	local humanoid = getHumanoid()
	humanoid.JumpHeight = 100
	SpeedButton.Visible = false
	JumpButton.Visible = false
	PowerButton.Visible = true
	screenGUI.Frame.Visible = false
	humanoid.WalkSpeed = 16
end)

SpeedButton.MouseButton1Click:Connect(function()
	local humanoid = getHumanoid()
	humanoid.WalkSpeed = 100
	SpeedButton.Visible = false
	JumpButton.Visible = false
	PowerButton.Visible = true
	screenGUI.Frame.Visible = false
	humanoid.JumpHeight = 7.2
end)
