local TweenService = game:GetService("TweenService")

local rarity = script.Parent:WaitForChild("Rarity")
local button = script.Parent:WaitForChild("Button")
local RNGOpener = button.Parent:WaitForChild("RNGOpening")

local debounce = true
local on = true

rarity.AnchorPoint = Vector2.new(0.5, 0.5)
rarity.Position = UDim2.new(0.5, 0, 0.5, 0) 

local tweenInfo = TweenInfo.new(0.5, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut)

local function shakeTween()
	local tweenInfo = TweenInfo.new(0.05, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
	local goal1 = {Rotation = 15, Size = UDim2.new(0.12, 0, 0.06, 0)}
	local goal2 = {Rotation = -15, Size = UDim2.new(0.12, 0, 0.06, 0)}
	local goal3 = {Rotation = 0, Size = UDim2.new(0.2, 0, 0.1, 0)}

	local t1 = TweenService:Create(rarity, tweenInfo, goal1)
	local t2 = TweenService:Create(rarity, tweenInfo, goal2)
	local t3 = TweenService:Create(rarity, tweenInfo, goal3)

	t1:Play()
	t1.Completed:Wait()
	t2:Play()
	t2.Completed:Wait()
	t3:Play()
end

local items = {
	{ name = "Common", chance = 60 },
	{ name = "Rare", chance = 25 },
	{ name = "Epic", chance = 10 },
	{ name = "Legendary", chance = 4 },
	{ name = "Mythic", chance = 1 }
}

function roll()
	local rng = math.random(1, 100)
	local cumulative = 0

	for _, item in ipairs(items) do
		cumulative += item.chance

		if rng <= cumulative then
			return item.name
		end
	end
end

function spinning()
	for i = 1, 10 do
		shakeTween()
		roll()
	end
end

RNGOpener.MouseButton1Click:Connect(function()
	if on == true then
		on = false
		debounce = false
		button.Visible = true
		rarity.Visible = true
	else
		on = true
		debounce = true
		button.Visible = false
		rarity.Visible = false
	end
end)

button.MouseButton1Click:Connect(function()
	if debounce then return end
	debounce = true
	spinning()
	rarity.Text = tostring(roll())
	task.wait(0.5)
	debounce = false
end)
